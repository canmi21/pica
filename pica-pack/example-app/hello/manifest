pkgname = hello
pkgver = 0.1.0-1
pkgdesc = Example lifecycle package
url = https://example.invalid
packager = pica-pack
license = GPL-3.0-only
proprietary = false

platform = all
arch = all
pica = 0.0.32

# Optional compatibility tags (recommended):
# uname = arm64

# Optional type tags (repeatable):
# type = cli
# type = luci
#
# If type includes luci, declare the implementation variant:
# luci = lua1
# luci = js2

# Optional: base dependencies (can be missing; pica warns only)
# base_depend = busybox

# Optional: kernel module dependencies (missing => install is rejected)
# kmod_depend = kmod-tun

# Optional: if you want pica to optionally install deps via opkg feeds,
# list them here. When depend/ exists and feeds match all/part of them,
# pica will ask whether to use feeds or packaged depend/.
depend = busybox

# Optional: list opkg packages for uninstall whitelist:
# opkg = luci

# Optional: if you want pica -R to delete installed /usr/bin files safely,
# list them explicitly (relative paths under /usr/bin):

cmd_install = cmd/install
cmd_update = cmd/update
cmd_remove = cmd/remove
